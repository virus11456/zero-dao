// This is your Prisma schema file.
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =========================================================
// AGENTS
// =========================================================

enum AgentRole {
  ceo
  engineer
  designer
  researcher
  marketing
  analyst
}

enum AgentStatus {
  idle
  running
  paused
  error
}

model Agent {
  id          String      @id @default(uuid())
  name        String
  role        AgentRole
  status      AgentStatus @default(idle)
  model       String      @default("claude-sonnet-4-6")
  systemPrompt String     @db.Text
  capabilities String[]   // e.g. ["typescript", "python", "seo", "react"]
  maxParallelTasks Int    @default(2)
  heartbeatIntervalSec Int @default(3600)
  lastHeartbeatAt DateTime?
  reportsToId String?
  reportsTo   Agent?      @relation("ReportsTo", fields: [reportsToId], references: [id])
  directReports Agent[]   @relation("ReportsTo")
  tasks       Task[]      @relation("AssignedTasks")
  runs        AgentRun[]
  memories    AgentMemory[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([status])
  @@index([role])
}

// =========================================================
// TASKS
// =========================================================

enum TaskStatus {
  backlog
  todo
  in_progress
  in_review
  done
  blocked
  cancelled
}

enum TaskPriority {
  critical
  high
  medium
  low
}

model Task {
  id          String       @id @default(uuid())
  identifier  String       @unique // e.g. ZD-1
  title       String
  description String?      @db.Text
  status      TaskStatus   @default(todo)
  priority    TaskPriority @default(medium)
  projectId   String?
  project     Project?     @relation(fields: [projectId], references: [id])
  goalId      String?
  goal        Goal?        @relation("GoalTasks", fields: [goalId], references: [id])
  parentId    String?
  parent      Task?        @relation("SubTasks", fields: [parentId], references: [id])
  subtasks    Task[]       @relation("SubTasks")
  assigneeId  String?
  assignee    Agent?       @relation("AssignedTasks", fields: [assigneeId], references: [id])
  labels      String[]
  blockedReason String?    @db.Text
  completedAt DateTime?
  dueDate     DateTime?
  comments    TaskComment[]
  runs        AgentRun[]
  documents   TaskDocument[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([status])
  @@index([assigneeId])
  @@index([projectId])
  @@index([goalId])
}

model TaskComment {
  id        String   @id @default(uuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id])
  authorId  String?  // null = system or board
  content   String   @db.Text
  isSystem  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([taskId])
}

model TaskDocument {
  id         String   @id @default(uuid())
  taskId     String
  task       Task     @relation(fields: [taskId], references: [id])
  key        String   // e.g. "plan", "spec", "notes"
  title      String
  body       String   @db.Text
  format     String   @default("markdown")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([taskId, key])
}

// =========================================================
// PROJECTS
// =========================================================

enum ProjectStatus {
  planned
  active
  paused
  completed
  archived
}

model Project {
  id          String        @id @default(uuid())
  name        String
  description String?       @db.Text
  status      ProjectStatus @default(planned)
  repoUrl     String?
  tasks       Task[]
  goals       Goal[]
  targetDate  DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

// =========================================================
// GOALS (DAO autonomous planning layer)
// =========================================================

enum GoalStatus {
  draft      // not yet activated
  planning   // being decomposed into tasks
  active     // tasks are running
  completed  // all tasks done
  paused
  cancelled
}

model Goal {
  id          String     @id @default(uuid())
  title       String
  description String?    @db.Text
  status      GoalStatus @default(draft)
  projectId   String?
  project     Project?   @relation(fields: [projectId], references: [id])
  tasks       Task[]     @relation("GoalTasks")
  // Metrics for self-improvement
  tasksCreated Int       @default(0)
  tasksDone    Int       @default(0)
  selfHealCount Int      @default(0)
  completedAt DateTime?
  targetDate  DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([status])
}

// =========================================================
// AGENT RUNS
// =========================================================

enum RunStatus {
  running
  completed
  failed
  timeout
}

model AgentRun {
  id        String    @id @default(uuid())
  agentId   String
  agent     Agent     @relation(fields: [agentId], references: [id])
  taskId    String?
  task      Task?     @relation(fields: [taskId], references: [id])
  status    RunStatus @default(running)
  inputTokens  Int    @default(0)
  outputTokens Int    @default(0)
  costCents    Int    @default(0)
  startedAt DateTime  @default(now())
  completedAt DateTime?
  error     String?   @db.Text
  logs      String[]

  @@index([agentId])
  @@index([taskId])
  @@index([status])
}

// =========================================================
// MEMORY
// =========================================================

model AgentMemory {
  id        String   @id @default(uuid())
  agentId   String
  agent     Agent    @relation(fields: [agentId], references: [id])
  type      String   // "user", "feedback", "project", "reference"
  key       String   // slug identifier
  title     String
  body      String   @db.Text
  tags      String[]
  accessCount Int    @default(0)
  lastAccessAt DateTime?
  supersededBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([agentId, key])
  @@index([agentId])
  @@index([type])
}

// =========================================================
// NOTIFICATIONS
// =========================================================

model Notification {
  id        String   @id @default(uuid())
  channel   String   // "telegram", "email"
  recipient String   // chat_id or email
  subject   String?
  body      String   @db.Text
  sentAt    DateTime?
  error     String?
  createdAt DateTime @default(now())
}

// =========================================================
// TASK AUTO-NUMBER SEQUENCE
// =========================================================
model TaskSequence {
  id      String @id @default("singleton")
  nextNum Int    @default(1)
}

// =========================================================
// GENESIS CONSTITUTION
// =========================================================

/**
 * BoardMember — tracks human board members for governance quorum calculation.
 * Each board member gets one vote (configurable weight).
 */
model BoardMember {
  id          String   @id @default(uuid())
  userId      String   @unique  // external user ID (e.g. Paperclip userId)
  name        String
  email       String?
  voteWeight  Int      @default(1)
  isActive    Boolean  @default(true)
  joinedAt    DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
}

model Constitution {
  id         String     @id @default(uuid())
  version    Int        @default(1)
  body       String     @db.Text
  rules      Json       @default("{}")
  isActive   Boolean    @default(true)
  ratifiedAt DateTime?
  proposals  Proposal[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

// =========================================================
// GOVERNANCE — PROPOSALS & VOTING
// =========================================================

enum ProposalStatus {
  open
  passed
  rejected
  executed
  expired
}

enum ProposalType {
  constitution_amendment
  profit_distribution
  agent_hire
  agent_fire
  budget_allocation
  strategic_pivot
  custom
}

model Proposal {
  id                String         @id @default(uuid())
  constitutionId    String
  constitution      Constitution   @relation(fields: [constitutionId], references: [id])
  type              ProposalType
  title             String
  description       String         @db.Text
  payload           Json           @default("{}")
  status            ProposalStatus @default(open)
  proposedByAgentId String?
  proposedByUserId  String?
  votingDeadline    DateTime
  quorumPercent     Int            @default(51)
  passThreshold     Int            @default(51)
  votes             Vote[]
  executedAt        DateTime?
  executionNote     String?        @db.Text
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([status])
  @@index([type])
}

enum VoteChoice {
  yes
  no
  abstain
}

model Vote {
  id           String     @id @default(uuid())
  proposalId   String
  proposal     Proposal   @relation(fields: [proposalId], references: [id])
  voterAgentId String?
  voterUserId  String?
  weight       Int        @default(1)
  choice       VoteChoice
  rationale    String?    @db.Text
  createdAt    DateTime   @default(now())

  @@unique([proposalId, voterAgentId])
  @@unique([proposalId, voterUserId])
  @@index([proposalId])
}

// =========================================================
// PROFIT DISTRIBUTION
// =========================================================

model IncomeEvent {
  id             String        @id @default(uuid())
  source         String
  description    String?       @db.Text
  amountCents    Int
  currency       String        @default("TWD")
  distributionId String?       @unique
  distribution   Distribution? @relation(fields: [distributionId], references: [id])
  recordedAt     DateTime      @default(now())
  createdAt      DateTime      @default(now())
}

model Distribution {
  id             String                 @id @default(uuid())
  totalCents     Int
  currency       String                 @default("TWD")
  rulesSnapshot  Json
  lineItems      DistributionLineItem[]
  incomeEvent    IncomeEvent?
  executedAt     DateTime?
  createdAt      DateTime               @default(now())
}

model DistributionLineItem {
  id             String       @id @default(uuid())
  distributionId String
  distribution   Distribution @relation(fields: [distributionId], references: [id])
  recipient      String
  label          String
  percent        Int
  amountCents    Int
  paid           Boolean      @default(false)
  paidAt         DateTime?
  note           String?

  @@index([distributionId])
}

// =========================================================
// FINANCIAL ACCOUNTING (Double-Entry Bookkeeping)
// =========================================================

/**
 * Chart of Accounts — defines all financial accounts.
 * Uses standard accounting categories aligned with financial statements.
 */

enum AccountType {
  asset          // Balance Sheet: what we own (cash, AR, equipment)
  liability      // Balance Sheet: what we owe (AP, loans)
  equity         // Balance Sheet: owner's stake (capital, retained earnings)
  revenue        // P&L: income from operations
  expense        // P&L: costs of operations
  cogs           // P&L: cost of goods/services sold
}

model Account {
  id          String      @id @default(uuid())
  code        String      @unique  // e.g. "1001" (cash), "4001" (revenue)
  name        String               // e.g. "現金", "銷售收入"
  nameEn      String?              // English name
  type        AccountType
  currency    String      @default("TWD")
  isActive    Boolean     @default(true)
  description String?
  entries     JournalEntry[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([type])
  @@index([code])
}

/**
 * Journal — each financial event. Uses double-entry: every transaction
 * has equal debits and credits.
 */

enum JournalStatus {
  draft
  posted    // finalized, affects reports
  voided    // cancelled, excluded from reports
}

model Journal {
  id          String        @id @default(uuid())
  date        DateTime      @default(now())
  description String        @db.Text
  reference   String?       // e.g. invoice number, receipt ID
  status      JournalStatus @default(draft)
  currency    String        @default("TWD")
  // Link to source events
  incomeEventId    String?
  distributionId   String?
  entries          JournalEntry[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([date])
  @@index([status])
}

/**
 * Journal Entry — one line in a journal (debit or credit).
 * Debit: increases assets/expenses; decreases liabilities/equity/revenue.
 * Credit: increases liabilities/equity/revenue; decreases assets/expenses.
 */

enum EntryType {
  debit
  credit
}

model JournalEntry {
  id          String     @id @default(uuid())
  journalId   String
  journal     Journal    @relation(fields: [journalId], references: [id])
  accountId   String
  account     Account    @relation(fields: [accountId], references: [id])
  type        EntryType
  amountCents Int
  memo        String?
  createdAt   DateTime   @default(now())

  @@index([journalId])
  @@index([accountId])
}

/**
 * FinancialReport — cached/generated financial statements.
 * Regenerated on demand or on schedule.
 */

enum ReportType {
  income_statement   // 損益表 P&L
  balance_sheet      // 資產負債表
  cash_flow          // 現金流量表
  trial_balance      // 試算表
}

model FinancialReport {
  id          String     @id @default(uuid())
  type        ReportType
  periodStart DateTime
  periodEnd   DateTime
  currency    String     @default("TWD")
  // The report data as structured JSON
  data        Json
  summary     String?    @db.Text  // AI-generated narrative analysis
  generatedAt DateTime   @default(now())

  @@index([type])
  @@index([periodStart])
}

// =========================================================
// COMPANY ARCHIVE (會議記錄 / 決策檔案庫)
// =========================================================

enum ArchiveEntryType {
  board_decision      // 董事會決議
  meeting_minutes     // 會議記錄
  policy_change       // 政策變更
  agent_action        // Agent 重大行動記錄
  goal_completion     // 目標完成記錄
  incident            // 事件記錄
  financial_milestone // 財務里程碑
  strategic_note      // 策略備忘錄
}

model ArchiveEntry {
  id          String           @id @default(uuid())
  type        ArchiveEntryType
  title       String
  summary     String           @db.Text
  body        String           @db.Text
  // Linked entities (optional)
  proposalId  String?
  goalId      String?
  // Author
  authorAgentId String?
  authorUserId  String?
  // Tags for searching
  tags        String[]
  // Attachments as JSON (key-value pairs: name → url/content)
  attachments Json             @default("[]")
  // Was this AI-generated or human-written?
  isAutoGenerated Boolean      @default(false)
  occurredAt  DateTime         @default(now())
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([type])
  @@index([occurredAt])
  @@index([proposalId])
  @@index([goalId])
}
