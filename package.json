{
  "name": "zero-dao",
  "version": "0.1.0",
  "description": "A zero-human, fully automated company orchestration framework",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc || true",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "migrate": "prisma migrate deploy",
    "migrate:dev": "prisma migrate dev",
    "studio": "prisma studio",
    "db:push": "prisma db push",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src/**/*.ts",
    "demo:seed": "tsx prisma/demo-seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@prisma/client": "^5.22.0",
    "axios": "^1.7.7",
    "bull": "^4.16.3",
    "cron": "^3.1.7",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "ioredis": "^5.4.1",
    "node-telegram-bot-api": "^0.66.0",
    "octokit": "^4.0.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bull": "^4.10.0",
    "@types/cron": "^2.4.3",
    "@types/express": "^5.0.0",
    "@types/node": "^22.8.4",
    "@types/node-telegram-bot-api": "^0.64.7",
    "prisma": "^5.22.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
