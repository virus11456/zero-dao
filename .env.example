# Environment Configuration
# Copy this file to .env and fill in real values

# === Core ===
NODE_ENV=development
PORT=3200

# === API Authentication ===
# Set a strong random key. All /api/* requests require this key.
# Leave empty to disable auth (development only).
API_KEY="your-secret-api-key-here"

# === Database ===
DATABASE_URL="postgresql://user:password@localhost:5432/zero_dao"

# === Redis ===
REDIS_URL="redis://localhost:6379"

# === AI Provider (Anthropic via proxy) ===
ANTHROPIC_API_KEY="your-api-key"
ANTHROPIC_BASE_URL="https://api.acetoken.ai/"
AI_MODEL="claude-sonnet-4-6"

# === GitHub ===
GITHUB_TOKEN="your-github-pat"
GITHUB_ORG="virus11456"

# === Telegram ===
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"
TELEGRAM_ADMIN_CHAT_ID="832659652"

# === Heartbeat ===
HEARTBEAT_INTERVAL_SEC=3600
MAX_CONCURRENT_AGENTS=5

# === Projects ===
# Comma-separated list of active project repos
ACTIVE_REPOS="virus11456/zero-dao,virus11456/wateramry,virus11456/polybot,virus11456/hypebigboss"
